# Copy to .env. Blank optional keys = feature skipped. Minimum: AI_GATEWAY_API_KEY (+ TELEGRAM_* for the bot).

# bot token (@BotFather)
TELEGRAM_TOKEN=
# your chat id — single-user gate (@userinfobot)
TELEGRAM_CHAT_ID=

# all LLM inference, via Vercel AI Gateway
AI_GATEWAY_API_KEY=

# bash cwd + file-tool root. default ./workspace
WORKSPACE_ROOT=
# memory dir, relative to WORKSPACE_ROOT. default memory
MEMORY_ROOT=

# web search (Tavily)
TAVILY_API_KEY=
# Gmail + Calendar (Composio) — both required
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=

# Laminar tracing key
LMNR_PROJECT_API_KEY=
# self-hosted Laminar (optional)
LMNR_BASE_URL=
LMNR_HTTP_PORT=
LMNR_GRPC_PORT=
